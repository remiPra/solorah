---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldDivider from '../../components/ui/GoldDivider.astro';
import ContactForm from '../../components/ContactForm';
import { useTranslations } from '../../i18n/utils';

const lang = 'ja';
const t = useTranslations(lang);

const contactLabels = {
  name: t('pages.contact.nameLabel'),
  email: t('pages.contact.emailLabel'),
  message: t('pages.contact.messageLabel'),
  send: t('pages.contact.send'),
  namePlaceholder: t('pages.contact.namePlaceholder'),
  emailPlaceholder: t('pages.contact.emailPlaceholder'),
  messagePlaceholder: t('pages.contact.messagePlaceholder'),
  success: t('pages.contact.success'),
  error: t('pages.contact.error'),
  consent: t('pages.contact.consent'),
};
---

<BaseLayout
  title={t('pages.contact.title')}
  description={t('pages.contact.metaDescription')}
  lang={lang}
>
  <section class="py-24 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <GoldDivider class="max-w-xs mx-auto mb-8" />
        <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-4">
          {t('pages.contact.title')}
        </h1>
        <p class="font-body text-lg text-sol-cream italic">
          {t('pages.contact.subtitle')}
        </p>
      </div>

      <ContactForm client:only="react" lang={lang} labels={contactLabels} />
    </div>
  </section>
</BaseLayout>
