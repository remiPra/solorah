---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoldDivider from '../../../components/ui/GoldDivider.astro';
import OracleReading from '../../../components/cards/OracleReading';
import { oracleAmourDeck } from '../../../data/oracle-amour';
import { useTranslations } from '../../../i18n/utils';

const lang = 'ja';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.loveReading.title')}
  description={t('pages.loveReading.metaDescription')}
  lang={lang}
>
  <section class="pt-24 pb-8 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-6">
        {t('pages.loveReading.title')}
      </h1>
      <p class="font-body text-lg text-sol-cream leading-relaxed mb-4">
        愛のオラクルからカードを1枚引いて、宇宙があなたの心に用意したメッセージを発見しましょう。44枚のカードがあなたの恋愛を照らします。
      </p>
      <p class="font-body text-sol-ash text-base italic">
        恋の質問に集中して、直感に導かれるままカードを選んでください。
      </p>
    </div>
  </section>

  <OracleReading client:only="react" lang={lang} deck={oracleAmourDeck.cards} />

  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-2xl text-sol-gold text-center mb-10">よくある質問</h2>
      <div class="space-y-6">
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">恋愛占いはどのように機能しますか？</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">恋の質問に集中し、カードをスクロールして、呼びかけるカードを選んでください。愛のオラクルがパーソナライズされたメッセージを届けます。</p>
        </details>
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">複数回占えますか？</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">はい、何度でもやり直せます。ただし、より正確な結果のために、1セッションにつき1つの質問に集中することをお勧めします。</p>
        </details>
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">無料ですか？</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">はい、すべての占いは100%無料で、登録不要です。より深い洞察が必要な場合は、パーソナル相談をリクエストできます。</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>
