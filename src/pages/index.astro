---
// Root page — redirects to /fr/ by default
// Language detection happens client-side to stay SSG-compatible
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Solorah — Oracle & Tarot</title>
    <meta http-equiv="refresh" content="0;url=/fr/" />
    <link rel="canonical" href="https://solorah.com/fr/" />
    <script is:inline>
      // Detect preferred language and redirect
      var lang = navigator.language || (navigator.languages && navigator.languages[0]) || 'fr';
      var target = '/fr/';
      if (lang.startsWith('en')) target = '/en/';
      else if (lang.startsWith('zh')) target = '/zh/';
      else if (lang.startsWith('es')) target = '/es/';
      window.location.replace(target);
    </script>
  </head>
  <body></body>
</html>
