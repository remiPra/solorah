---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldDivider from '../../components/ui/GoldDivider.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'fr';
const t = useTranslations(lang);
const lastUpdated = '1er avril 2026';
---

<BaseLayout
  title="Politique de confidentialité"
  description="Politique de confidentialité de Solorah.com — comment nous protégeons vos données personnelles."
  lang={lang}
>
  <section class="py-24 px-4">
    <div class="max-w-3xl mx-auto">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-4 text-center">
        Politique de confidentialité
      </h1>
      <p class="text-center text-sol-ash mb-12 font-ui text-sm">Dernière mise à jour : {lastUpdated}</p>

      <div class="font-body text-lg text-sol-cream leading-relaxed space-y-10">

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">1. Responsable de traitement</h2>
          <p>
            Solorah<br />
            Email : <a href="mailto:contact@solorah.com" class="text-sol-gold underline">contact@solorah.com</a>
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">2. Données collectées</h2>

          <div class="space-y-6 ml-4">
            <div>
              <h3 class="font-display text-lg text-sol-cream mb-2">a) Formulaire de contact</h3>
              <ul class="list-disc ml-6 space-y-1 text-sol-ash">
                <li><strong>Données :</strong> nom, email, message</li>
                <li><strong>Finalité :</strong> répondre à votre demande</li>
                <li><strong>Base légale :</strong> consentement (RGPD art. 6.1.a)</li>
                <li><strong>Durée :</strong> 12 mois après traitement de la demande</li>
              </ul>
            </div>

            <div>
              <h3 class="font-display text-lg text-sol-cream mb-2">b) Compte utilisateur</h3>
              <ul class="list-disc ml-6 space-y-1 text-sol-ash">
                <li><strong>Données :</strong> adresse email (via lien de connexion magique)</li>
                <li><strong>Finalité :</strong> accès aux fonctionnalités de sauvegarde des tirages</li>
                <li><strong>Base légale :</strong> exécution du contrat (RGPD art. 6.1.b)</li>
                <li><strong>Durée :</strong> jusqu'à suppression du compte par l'utilisateur</li>
              </ul>
            </div>

            <div>
              <h3 class="font-display text-lg text-sol-cream mb-2">c) Tirages sauvegardés</h3>
              <ul class="list-disc ml-6 space-y-1 text-sol-ash">
                <li><strong>Données :</strong> type de tirage, cartes tirées, question posée, date</li>
                <li><strong>Finalité :</strong> permettre la consultation de votre historique personnel</li>
                <li><strong>Base légale :</strong> exécution du contrat (RGPD art. 6.1.b)</li>
                <li><strong>Durée :</strong> jusqu'à suppression du compte</li>
              </ul>
              <p class="text-sol-ash/80 text-base mt-2 italic">
                Note : les questions posées lors des tirages peuvent contenir des informations à caractère personnel sensible (vie sentimentale, santé, etc.). En sauvegardant un tirage, vous consentez au traitement de ces informations.
              </p>
            </div>

            <div>
              <h3 class="font-display text-lg text-sol-cream mb-2">d) Profil utilisateur</h3>
              <ul class="list-disc ml-6 space-y-1 text-sol-ash">
                <li><strong>Données :</strong> nom d'affichage (optionnel), langue préférée</li>
                <li><strong>Finalité :</strong> personnalisation de l'expérience</li>
                <li><strong>Base légale :</strong> exécution du contrat (RGPD art. 6.1.b)</li>
                <li><strong>Durée :</strong> jusqu'à suppression du compte</li>
              </ul>
            </div>

            <div>
              <h3 class="font-display text-lg text-sol-cream mb-2">e) Données techniques</h3>
              <ul class="list-disc ml-6 space-y-1 text-sol-ash">
                <li><strong>Données :</strong> adresse IP, tokens de session</li>
                <li><strong>Finalité :</strong> sécurité et bon fonctionnement du site</li>
                <li><strong>Base légale :</strong> intérêt légitime (RGPD art. 6.1.f)</li>
                <li><strong>Durée :</strong> durée de la session</li>
              </ul>
            </div>
          </div>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">3. Cookies et stockage local</h2>
          <p>Ce site utilise :</p>
          <ul class="list-disc ml-6 space-y-2 text-sol-ash mt-3">
            <li><strong>Cookies de session</strong> (Firebase Auth) : strictement nécessaires au fonctionnement, exemptés de consentement selon la directive ePrivacy.</li>
            <li><strong>Stockage local (localStorage)</strong> : préférences d'affichage (thème clair/sombre, volume audio, choix de consentement analytics). Ces données ne sont pas des données personnelles.</li>
            <li><strong>Google Analytics (GA4)</strong> : mesure d'audience avec IP anonymisée, sans partage avec Google Ads et sans personnalisation publicitaire. Chargé <strong>uniquement après consentement explicite</strong> via le bandeau. Vous pouvez refuser ou retirer votre consentement à tout moment via le bouton « Gérer les cookies » en bas de page.</li>
          </ul>
          <p class="mt-3 font-semibold">Aucun cookie publicitaire n'est utilisé sur ce site.</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">4. Sous-traitants</h2>
          <p class="mb-4">Vos données sont traitées par les sous-traitants suivants :</p>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sol-ash">
              <thead>
                <tr class="border-b border-sol-gold/20">
                  <th class="pb-2 pr-4 text-sol-gold font-display">Sous-traitant</th>
                  <th class="pb-2 pr-4 text-sol-gold font-display">Rôle</th>
                  <th class="pb-2 text-sol-gold font-display">Localisation</th>
                </tr>
              </thead>
              <tbody class="text-base">
                <tr class="border-b border-sol-gold/10">
                  <td class="py-2 pr-4">Google LLC (Firebase)</td>
                  <td class="py-2 pr-4">Base de données, authentification</td>
                  <td class="py-2">USA</td>
                </tr>
                <tr class="border-b border-sol-gold/10">
                  <td class="py-2 pr-4">Google LLC (Analytics)</td>
                  <td class="py-2 pr-4">Mesure d'audience (après consentement)</td>
                  <td class="py-2">USA</td>
                </tr>
                <tr class="border-b border-sol-gold/10">
                  <td class="py-2 pr-4">Resend Inc.</td>
                  <td class="py-2 pr-4">Envoi d'emails transactionnels</td>
                  <td class="py-2">USA</td>
                </tr>
                <tr>
                  <td class="py-2 pr-4">Vercel Inc.</td>
                  <td class="py-2 pr-4">Hébergement du site web</td>
                  <td class="py-2">USA</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-sol-ash/80 text-base mt-3 italic">
            Des transferts de données hors Union Européenne sont effectués vers les États-Unis. Ces sous-traitants sont couverts par le EU-US Data Privacy Framework ou des clauses contractuelles types (CCT) conformes au RGPD.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">5. Vos droits (RGPD art. 15 à 21)</h2>
          <p>Vous disposez des droits suivants :</p>
          <ul class="list-disc ml-6 space-y-1 text-sol-ash mt-3">
            <li>Droit d'accès à vos données</li>
            <li>Droit de rectification</li>
            <li>Droit à l'effacement ("droit à l'oubli")</li>
            <li>Droit à la portabilité</li>
            <li>Droit d'opposition au traitement</li>
            <li>Droit à la limitation du traitement</li>
          </ul>
          <p class="mt-4">
            Pour exercer ces droits : <a href="mailto:contact@solorah.com" class="text-sol-gold underline">contact@solorah.com</a><br />
            Délai de réponse : 30 jours maximum.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">6. Suppression de votre compte</h2>
          <p>
            Vous pouvez demander la suppression de votre compte et de toutes vos données associées (tirages sauvegardés, profil, messages) en écrivant à <a href="mailto:contact@solorah.com" class="text-sol-gold underline">contact@solorah.com</a>. La suppression sera effectuée sous 30 jours.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">7. Réclamation</h2>
          <p>
            Si vous estimez que le traitement de vos données ne respecte pas la réglementation en vigueur, vous pouvez déposer une réclamation auprès de la CNIL :<br />
            <a href="https://www.cnil.fr" target="_blank" rel="noopener noreferrer" class="text-sol-gold underline">www.cnil.fr</a>
          </p>
        </div>

        <div class="pt-4 border-t border-sol-gold/10">
          <p class="italic text-sol-ash text-base">
            {t('footer.disclaimer')}
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
