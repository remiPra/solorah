---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldDivider from '../../components/ui/GoldDivider.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.legal.title')}
  description={t('pages.legal.metaDescription')}
  lang={lang}
>
  <section class="py-24 px-4">
    <div class="max-w-3xl mx-auto">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-12 text-center">
        {t('pages.legal.title')}
      </h1>

      <div class="font-body text-lg text-sol-cream leading-relaxed space-y-8">
        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">Editor del sitio</h2>
          <p>Solorah<br />Sitio web: solorah.com<br />Email: contact@solorah.com</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">Alojamiento</h2>
          <p>Este sitio web está alojado por Vercel Inc.<br />440 N Barranca Ave #4133, Covina, CA 91723, USA</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">Propiedad intelectual</h2>
          <p>Todo el contenido (textos, imágenes, ilustraciones, cartas) presente en este sitio está protegido por derechos de autor. Cualquier reproducción, incluso parcial, está prohibida sin autorización previa.</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">Protección de datos</h2>
          <p>De acuerdo con el RGPD, usted tiene derecho de acceso, rectificación y supresión de sus datos personales. Para ejercer estos derechos, contáctenos en: contact@solorah.com</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">Aviso</h2>
          <p class="italic text-sol-ash">
            {t('footer.disclaimer')}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
