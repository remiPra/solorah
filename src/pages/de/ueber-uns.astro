---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldDivider from '../../components/ui/GoldDivider.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.about.title')}
  description={t('pages.about.metaDescription')}
  lang={lang}
>
  <section class="py-24 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-8">
        {t('pages.about.title')}
      </h1>
      <div class="font-body text-lg text-sol-cream leading-relaxed space-y-6">
        <p>
          Solorah wurde aus einer Leidenschaft für die Wahrsagekunst und dem Wunsch geboren, Orakel und Tarot für alle zugänglich zu machen, überall auf der Welt.
        </p>
        <p>
          Unsere Mission ist es, einen heiligen Online-Raum zu schaffen, in dem jeder Mensch sich mit seiner Intuition verbinden und die Botschaften empfangen kann, die die Karten für ihn bereithalten.
        </p>
        <p>
          Ob du Antworten über dein Liebesleben mit dem Liebesorakel suchst oder alle Aspekte deines Lebens mit dem Tarot de Marseille erkunden möchtest — Solorah begleitet dich auf dieser Suche nach Sinn.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
