---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoldDivider from '../../../components/ui/GoldDivider.astro';
import OracleReading from '../../../components/cards/OracleReading';
import { oracleAmourDeck } from '../../../data/oracle-amour';
import { useTranslations } from '../../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.loveReading.title')}
  description={t('pages.loveReading.metaDescription')}
  lang={lang}
>
  <section class="pt-24 pb-8 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-6">
        {t('pages.loveReading.title')}
      </h1>
      <p class="font-body text-lg text-sol-cream leading-relaxed mb-4">
        Ziehe eine Karte aus dem Liebesorakel und entdecke die Botschaft, die das Universum für dein Herz bereithält. 44 Karten, um dein Liebesleben zu beleuchten.
      </p>
      <p class="font-body text-sol-ash text-base italic">
        Konzentriere dich auf deine Liebesfrage, dann lass deine Intuition deine Wahl leiten.
      </p>
    </div>
  </section>

  <OracleReading client:only="react" lang={lang} deck={oracleAmourDeck.cards} />

  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-2xl text-sol-gold text-center mb-10">Häufige Fragen</h2>
      <div class="space-y-6">
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">Wie funktioniert die Liebeslegung?</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">Konzentriere dich auf deine Liebesfrage, scrolle durch die Karten und wähle die, die dich anspricht. Das Liebesorakel wird dir eine persönliche Botschaft übermitteln.</p>
        </details>
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">Kann ich mehrere Ziehungen machen?</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">Ja, du kannst beliebig oft neu beginnen. Für eine genauere Ziehung empfehlen wir jedoch, dich auf eine einzige Frage pro Sitzung zu konzentrieren.</p>
        </details>
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">Ist die Ziehung kostenlos?</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">Ja, alle unsere Ziehungen sind 100% kostenlos und ohne Registrierung. Für tiefere Einblicke kannst du eine persönliche Beratung anfordern.</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>
