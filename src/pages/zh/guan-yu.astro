---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldDivider from '../../components/ui/GoldDivider.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.about.title')}
  description={t('pages.about.metaDescription')}
  lang={lang}
>
  <section class="py-24 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-8">
        {t('pages.about.title')}
      </h1>
      <div class="font-body text-lg text-sol-cream leading-relaxed space-y-6">
        <p>
          Solorah源于对占卜艺术的热爱，以及让世界各地的人都能接触到神谕和塔罗的愿望。
        </p>
        <p>
          我们的使命是创建一个神圣的在线空间，让每个人都能与自己的直觉连接，接收牌卡为你带来的讯息。
        </p>
        <p>
          无论你是通过爱情神谕寻找感情生活的答案，还是通过马赛塔罗探索生活的方方面面，Solorah都将陪伴你走过这段寻求意义的旅程。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
