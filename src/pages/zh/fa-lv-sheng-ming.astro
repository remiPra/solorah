---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoldDivider from '../../components/ui/GoldDivider.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.legal.title')}
  description={t('pages.legal.metaDescription')}
  lang={lang}
>
  <section class="py-24 px-4">
    <div class="max-w-3xl mx-auto">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-12 text-center">
        {t('pages.legal.title')}
      </h1>

      <div class="font-body text-lg text-sol-cream leading-relaxed space-y-8">
        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">网站发布者</h2>
          <p>Solorah<br />网站：solorah.com<br />邮箱：contact@solorah.com</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">托管服务</h2>
          <p>本网站由Vercel Inc.托管。<br />440 N Barranca Ave #4133, Covina, CA 91723, USA</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">知识产权</h2>
          <p>本网站所有内容（文字、图片、插图、牌卡）均受版权保护。未经事先授权，禁止任何形式的复制。</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">数据保护</h2>
          <p>根据GDPR规定，您有权访问、更正和删除您的个人数据。如需行使这些权利，请联系：contact@solorah.com</p>
        </div>

        <div>
          <h2 class="font-display text-xl text-sol-gold mb-3">免责声明</h2>
          <p class="italic text-sol-ash">
            {t('footer.disclaimer')}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
