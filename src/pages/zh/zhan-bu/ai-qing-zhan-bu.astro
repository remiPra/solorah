---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GoldDivider from '../../../components/ui/GoldDivider.astro';
import OracleReading from '../../../components/cards/OracleReading';
import { oracleAmourDeck } from '../../../data/oracle-amour';
import { useTranslations } from '../../../i18n/utils';

const lang = 'zh';
const t = useTranslations(lang);
---

<BaseLayout
  title={t('pages.loveReading.title')}
  description={t('pages.loveReading.metaDescription')}
  lang={lang}
>
  <section class="pt-24 pb-8 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <GoldDivider class="max-w-xs mx-auto mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl text-sol-gold mb-6">
        {t('pages.loveReading.title')}
      </h1>
      <p class="font-body text-lg text-sol-cream leading-relaxed mb-4">
        从爱情神谕中抽取一张牌，发现宇宙为你的心灵准备的信息。44张牌照亮你的感情生活。
      </p>
      <p class="font-body text-sol-ash text-base italic">
        专注于你的爱情问题，然后让直觉引导你的选择。
      </p>
    </div>
  </section>

  <OracleReading client:only="react" lang={lang} deck={oracleAmourDeck.cards} />

  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-2xl text-sol-gold text-center mb-10">常见问题</h2>
      <div class="space-y-6">
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">爱情占卜如何运作？</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">专注于你的爱情问题，滑动浏览牌卡并选择吸引你的那张。爱情神谕将为你传递个性化信息。</p>
        </details>
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">可以多次占卜吗？</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">可以，你可以随意重新开始。但为了更准确的占卜，我们建议每次专注于一个问题。</p>
        </details>
        <details class="group border border-sol-gold/10 rounded-lg p-4">
          <summary class="font-body text-sol-cream cursor-pointer font-semibold">占卜免费吗？</summary>
          <p class="font-body text-sol-ash mt-3 leading-relaxed">是的，我们所有的占卜都是100%免费的，无需注册。如需深入了解，可以申请个性化咨询。</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>
