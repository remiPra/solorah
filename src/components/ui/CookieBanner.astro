---
import type { Lang } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 hidden"
  role="status"
  aria-live="polite"
>
  <div class="bg-sol-charcoal/95 backdrop-blur-sm border-t border-sol-gold/10 px-4 py-3">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-ui text-xs text-sol-ash text-center sm:text-left leading-relaxed">
        {t('footer.cookies')}
      </p>
      <button
        id="cookie-accept"
        class="shrink-0 font-ui text-xs px-4 py-1.5 rounded border border-sol-gold/30 text-sol-gold hover:bg-sol-gold/10 transition-colors cursor-pointer"
      >
        {t('footer.cookiesOk')}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    if (!localStorage.getItem('solorah-cookies-ok')) {
      var banner = document.getElementById('cookie-banner');
      if (banner) banner.classList.remove('hidden');
    }
    document.addEventListener('click', function(e) {
      if (e.target && e.target.id === 'cookie-accept') {
        localStorage.setItem('solorah-cookies-ok', '1');
        var banner = document.getElementById('cookie-banner');
        if (banner) banner.classList.add('hidden');
      }
    });
  })();
</script>
