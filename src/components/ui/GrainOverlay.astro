---
// Grain overlay is now applied via body::before in global.css
// This component exists as a convenience wrapper if needed in specific sections
interface Props {
  class?: string;
  opacity?: number;
}

const { class: className = '', opacity = 0.04 } = Astro.props;
---

<div
  class:list={['absolute inset-0 pointer-events-none z-10', className]}
  style={`opacity: ${opacity}`}
  aria-hidden="true"
>
  <svg class="w-full h-full">
    <filter id="grain-local">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch" />
    </filter>
    <rect width="100%" height="100%" filter="url(#grain-local)" />
  </svg>
</div>
