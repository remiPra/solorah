---
import type { Lang } from '../../i18n/utils';
import { useTranslations, getTranslatedPath, getAlternateLang, languages } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
const altPath = getTranslatedPath(Astro.url.pathname, altLang);

const navLinks = [
  { href: `/${lang}`, label: t('nav.home') },
  { href: lang === 'fr' ? '/fr/tirage' : '/en/reading', label: t('nav.reading') },
  { href: `/${lang}/consultation`, label: t('nav.consultation') },
  { href: lang === 'fr' ? '/fr/a-propos' : '/en/about', label: t('nav.about') },
  { href: `/${lang}/contact`, label: t('nav.contact') },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="absolute inset-0 bg-sol-deep/80 backdrop-blur-md border-b border-sol-gold/10"></div>
  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={`/${lang}`} class="font-display text-xl sm:text-2xl text-sol-gold tracking-widest hover:text-sol-gold-light transition-colors">
      SOLORAH
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-ui text-sm text-sol-ash hover:text-sol-gold transition-colors tracking-wide uppercase"
        >
          {link.label}
        </a>
      ))}

      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="text-sol-ash hover:text-sol-gold transition-colors p-1.5 rounded-full border border-sol-gold/20 hover:border-sol-gold/50"
        aria-label="Toggle theme"
      >
        <!-- Sun (shown in dark mode) -->
        <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg id="icon-moon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <!-- Language Switcher -->
      <a
        href={altPath}
        class="font-ui text-sm text-sol-gold/70 hover:text-sol-gold border border-sol-gold/30 hover:border-sol-gold/60 rounded-full px-3 py-1 transition-all"
        aria-label={`Switch to ${languages[altLang]}`}
      >
        {altLang.toUpperCase()}
      </a>
    </div>

    <!-- Mobile: theme toggle + menu button -->
    <div class="flex md:hidden items-center gap-2">
      <button
        id="theme-toggle-mobile"
        class="text-sol-ash hover:text-sol-gold transition-colors p-2"
        aria-label="Toggle theme"
      >
        <svg id="icon-sun-mobile" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg id="icon-moon-mobile" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="text-sol-ash hover:text-sol-gold transition-colors p-2"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden relative bg-sol-deep/95 backdrop-blur-md border-b border-sol-gold/10">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block font-ui text-sm text-sol-ash hover:text-sol-gold transition-colors tracking-wide uppercase py-2"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-2 border-t border-sol-gold/10">
        <a
          href={altPath}
          class="inline-block font-ui text-sm text-sol-gold/70 hover:text-sol-gold border border-sol-gold/30 hover:border-sol-gold/60 rounded-full px-3 py-1 transition-all"
        >
          {languages[altLang]}
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  // Theme toggle logic
  function getTheme(): string {
    return document.documentElement.getAttribute('data-theme') || 'dark';
  }

  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('solorah-theme', theme);
    updateIcons(theme);
  }

  function updateIcons(theme: string) {
    const sunIcons = document.querySelectorAll('#icon-sun, #icon-sun-mobile');
    const moonIcons = document.querySelectorAll('#icon-moon, #icon-moon-mobile');

    sunIcons.forEach(el => {
      el.classList.toggle('hidden', theme !== 'dark');
    });
    moonIcons.forEach(el => {
      el.classList.toggle('hidden', theme !== 'light');
    });
  }

  function toggleTheme() {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  }

  // Init icons on load
  updateIcons(getTheme());

  // Bind click
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    if (menuIcon) {
      menuIcon.setAttribute(
        'd',
        isOpen ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12'
      );
    }
  });

  // Header shadow on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (header) {
      header.classList.toggle('shadow-lg', window.scrollY > 100);
    }
  }, { passive: true });
</script>
