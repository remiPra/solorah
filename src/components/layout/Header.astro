---
import type { Lang } from '../../i18n/utils';
import { useTranslations, getTranslatedPath, getOtherLangs, languages } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLangs = getOtherLangs(lang);

const navLinks = [
  { href: `/${lang}`, label: t('nav.home') },
  { href: getTranslatedPath(`/${lang}/tirage`, lang), label: t('nav.reading') },
  { href: getTranslatedPath(`/${lang}/consultation`, lang), label: t('nav.consultation') },
  { href: getTranslatedPath(`/${lang}/a-propos`, lang), label: t('nav.about') },
  { href: getTranslatedPath(`/${lang}/contact`, lang), label: t('nav.contact') },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="absolute inset-0 bg-sol-deep/80 backdrop-blur-md border-b border-sol-gold/10"></div>
  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={`/${lang}`} class="font-display text-xl sm:text-2xl text-sol-gold tracking-widest hover:text-sol-gold-light transition-colors">
      SOLORAH
    </a>

    <!-- Right side: theme toggle + hamburger (all screens) -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="text-sol-ash hover:text-sol-gold transition-colors p-2 rounded-full border border-sol-gold/20 hover:border-sol-gold/50"
        aria-label="Toggle theme"
      >
        <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg id="icon-moon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <!-- Hamburger (all screens) -->
      <button
        id="menu-btn"
        class="relative z-[60] text-sol-ash hover:text-sol-gold transition-colors p-2"
        aria-label="Menu"
        aria-expanded="false"
      >
        <div class="w-6 h-5 relative flex flex-col justify-between">
          <span id="bar-1" class="block h-[1.5px] w-full bg-current transition-all duration-300 origin-center"></span>
          <span id="bar-2" class="block h-[1.5px] w-full bg-current transition-all duration-300 origin-center"></span>
          <span id="bar-3" class="block h-[1.5px] w-full bg-current transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </nav>
</header>

<!-- Fullscreen Drawer (all screens) -->
<div id="drawer-backdrop" class="fixed inset-0 z-[55] pointer-events-none opacity-0 bg-sol-deep/95 backdrop-blur-md transition-opacity duration-500"></div>

<div id="drawer" class="fixed inset-0 z-[55] pointer-events-none -translate-y-full transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]">
  <div class="absolute inset-0 bg-gradient-to-b from-sol-deep via-sol-charcoal to-sol-deep"></div>

  <!-- Close button (X) top right -->
  <button
    id="drawer-close"
    class="absolute top-5 right-5 z-10 text-sol-ash hover:text-sol-gold transition-colors p-2"
    aria-label="Close menu"
  >
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <div class="relative h-full flex flex-col items-center justify-center px-6">
    <!-- Logo in drawer -->
    <div id="drawer-logo" class="mb-10 opacity-0 translate-y-8 transition-all duration-500">
      <div class="w-16 h-px bg-gradient-to-r from-transparent via-sol-gold/40 to-transparent mx-auto mb-4"></div>
      <span class="font-display text-2xl sm:text-3xl text-sol-gold tracking-[0.3em]">SOLORAH</span>
      <div class="w-16 h-px bg-gradient-to-r from-transparent via-sol-gold/40 to-transparent mx-auto mt-4"></div>
    </div>

    <!-- Nav links -->
    <nav class="w-full max-w-sm space-y-0">
      {navLinks.map((link, i) => (
        <div>
          {i > 0 && <div class="h-px bg-sol-gold/10"></div>}
          <a
            href={link.href}
            class="drawer-link block text-center font-display text-2xl sm:text-3xl font-bold tracking-wider py-4 sm:py-5 text-sol-cream hover:text-sol-gold transition-colors opacity-0 translate-y-8"
            style="transition-duration: 500ms"
          >
            {link.label}
          </a>
        </div>
      ))}

      <!-- Language switcher in drawer -->
      <div class="h-px bg-sol-gold/10"></div>
      <div
        id="drawer-langs"
        class="flex items-center justify-center gap-4 py-5 opacity-0 translate-y-8 transition-all duration-500"
      >
        {otherLangs.map((otherLang) => (
          <a
            href={getTranslatedPath(Astro.url.pathname, otherLang)}
            class="drawer-link font-ui text-sm text-sol-gold/70 hover:text-sol-gold border border-sol-gold/30 hover:border-sol-gold/60 rounded-full px-4 py-1.5 transition-all"
          >
            {languages[otherLang]}
          </a>
        ))}
      </div>
    </nav>
  </div>
</div>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  // Theme toggle logic
  function getTheme(): string {
    return document.documentElement.getAttribute('data-theme') || 'light';
  }

  function setTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('solorah-theme', theme);
    updateIcons(theme);
  }

  function updateIcons(theme: string) {
    document.querySelectorAll('#icon-sun').forEach(el => {
      el.classList.toggle('hidden', theme !== 'dark');
    });
    document.querySelectorAll('#icon-moon').forEach(el => {
      el.classList.toggle('hidden', theme !== 'light');
    });
  }

  function toggleTheme() {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  }

  // Drawer state
  let drawerOpen = false;

  function openDrawer() {
    drawerOpen = true;
    const backdrop = document.getElementById('drawer-backdrop');
    const drawer = document.getElementById('drawer');
    const logo = document.getElementById('drawer-logo');
    const links = document.querySelectorAll('.drawer-link');
    const langs = document.getElementById('drawer-langs');
    const bar1 = document.getElementById('bar-1');
    const bar2 = document.getElementById('bar-2');
    const bar3 = document.getElementById('bar-3');

    document.body.style.overflow = 'hidden';

    // Hamburger → X
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = 'translateY(7px) rotate(45deg)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'translateY(-7px) rotate(-45deg)';
    }

    // Backdrop fade in
    if (backdrop) {
      backdrop.classList.remove('pointer-events-none');
      backdrop.style.transitionDelay = '10ms';
      backdrop.classList.remove('opacity-0');
      backdrop.classList.add('opacity-100');
    }

    // Drawer slide down
    if (drawer) {
      drawer.classList.remove('pointer-events-none');
      drawer.style.transitionDelay = '50ms';
      drawer.classList.remove('-translate-y-full');
      drawer.classList.add('translate-y-0');
    }

    // Logo stagger
    if (logo) {
      setTimeout(() => {
        logo.classList.remove('opacity-0', 'translate-y-8');
      }, 400);
    }

    // Links stagger
    links.forEach((link, i) => {
      setTimeout(() => {
        link.classList.remove('opacity-0', 'translate-y-8');
      }, 500 + i * 100);
    });

    // Langs stagger
    if (langs) {
      setTimeout(() => {
        langs.classList.remove('opacity-0', 'translate-y-8');
      }, 500 + links.length * 100);
    }
  }

  function closeDrawer() {
    drawerOpen = false;
    const backdrop = document.getElementById('drawer-backdrop');
    const drawer = document.getElementById('drawer');
    const logo = document.getElementById('drawer-logo');
    const links = document.querySelectorAll('.drawer-link');
    const langs = document.getElementById('drawer-langs');
    const bar1 = document.getElementById('bar-1');
    const bar2 = document.getElementById('bar-2');
    const bar3 = document.getElementById('bar-3');

    // X → Hamburger
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }

    // All content disappears at once
    if (logo) logo.classList.add('opacity-0', 'translate-y-8');
    links.forEach((link) => link.classList.add('opacity-0', 'translate-y-8'));
    if (langs) langs.classList.add('opacity-0', 'translate-y-8');

    // Drawer slide up
    if (drawer) {
      drawer.style.transitionDelay = '0ms';
      drawer.classList.remove('translate-y-0');
      drawer.classList.add('-translate-y-full');
    }

    // Backdrop fade out
    if (backdrop) {
      backdrop.style.transitionDelay = '0ms';
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
    }

    // Restore after animation
    setTimeout(() => {
      document.body.style.overflow = '';
      backdrop?.classList.add('pointer-events-none');
      drawer?.classList.add('pointer-events-none');
    }, 700);
  }

  function resetDrawer() {
    drawerOpen = false;
    const bar1 = document.getElementById('bar-1');
    const bar2 = document.getElementById('bar-2');
    const bar3 = document.getElementById('bar-3');
    if (bar1 && bar2 && bar3) {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }
    document.body.style.overflow = '';

    const backdrop = document.getElementById('drawer-backdrop');
    backdrop?.classList.add('pointer-events-none', 'opacity-0');
    backdrop?.classList.remove('opacity-100');

    const drawer = document.getElementById('drawer');
    drawer?.classList.add('pointer-events-none', '-translate-y-full');
    drawer?.classList.remove('translate-y-0');

    document.querySelectorAll('.drawer-link').forEach(l => l.classList.add('opacity-0', 'translate-y-8'));
    document.getElementById('drawer-logo')?.classList.add('opacity-0', 'translate-y-8');
    document.getElementById('drawer-langs')?.classList.add('opacity-0', 'translate-y-8');
  }

  function initHeader() {
    updateIcons(getTheme());

    document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);

    // Ensure drawer closed on navigation
    resetDrawer();

    // Hamburger toggle
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      if (drawerOpen) closeDrawer();
      else openDrawer();
    });

    // Close button (X) in drawer
    document.getElementById('drawer-close')?.addEventListener('click', closeDrawer);

    // Close on backdrop click
    document.getElementById('drawer-backdrop')?.addEventListener('click', closeDrawer);

    // Close on link click
    document.querySelectorAll('.drawer-link').forEach((link) => {
      link.addEventListener('click', closeDrawer);
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawerOpen) closeDrawer();
    });

    // Header shadow on scroll
    const header = document.getElementById('site-header');
    header?.classList.toggle('shadow-lg', window.scrollY > 100);
  }

  document.addEventListener('astro:page-load', initHeader);

  window.addEventListener('scroll', () => {
    const header = document.getElementById('site-header');
    if (header) {
      header.classList.toggle('shadow-lg', window.scrollY > 100);
    }
  }, { passive: true });
</script>
