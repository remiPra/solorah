rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Saved readings: users can only access their own
    match /saved_readings/{readingId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow update: if false; // readings are immutable
    }

    // Contact messages: only server (admin SDK) can read/write
    // Client-side has no access — all operations go through API endpoints
    match /contact_messages/{messageId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
